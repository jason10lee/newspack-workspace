		"@types/qs": "^6.15.1",
		"@types/react": "^19.2.2",
		"@typescript-eslint/parser": "^8.61.0",
		"@wordpress/browserslist-config": "^6.48.0",
		"@wordpress/eslint-plugin": "^22.19.0",
		"@wordpress/prettier-config": "^4.48.0",
		"@wordpress/scripts": "^30.26.0",
