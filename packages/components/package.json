{
	"name": "newspack-components",
	"version": "4.4.0-alpha.1",
	"description": "Newspack design system components",
	"author": "Automattic",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"newspack",
		"components"
	],
	"bugs": {
		"url": "https://github.com/Automattic/newspack-plugin/issues"
	},
	"homepage": "https://github.com/Automattic/newspack-plugin",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/newspack-workspace.git",
		"directory": "packages/components"
	},
	"main": "dist/esm/index.js",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"classnames": "^2.3.1",
		"lodash": "^4.17.21",
		"moment-range": "^3.1.1",
		"qs": "^6.15.2",
		"react-router-dom": "^5.3.4",
		"@babel/runtime": "^7.29.7",
		"colord": "^2.9.0"
	},
	"peerDependencies": {
		"@wordpress/api-fetch": "^7.48.0",
		"@wordpress/base-styles": "^6.9.0",
		"@wordpress/components": "^30.6.0",
		"@wordpress/compose": "^7.33.0",
		"@wordpress/data": "^10.48.0",
		"@wordpress/dataviews": "^10.2.0",
		"@wordpress/dom-ready": "^4.48.0",
		"@wordpress/element": "^6.33.0",
		"@wordpress/hooks": "^4.48.0",
		"@wordpress/html-entities": "^4.48.0",
		"@wordpress/i18n": "^6.21.0",
		"@wordpress/icons": "^11.0.0",
		"@wordpress/keycodes": "^4.48.0",
		"@wordpress/url": "^4.48.0"
	},
	"devDependencies": {
		"@babel/cli": "^7.29.7",
		"@babel/core": "^7.29.7",
		"@babel/preset-env": "^7.29.7",
		"@babel/preset-react": "^7.29.7",
		"@babel/preset-typescript": "^7.29.7",
		"recursive-copy": "^2.0.0"
	},
	"babel": {
		"ignore": [
			"./node_modules",
			"./dist",
			"./shared"
		]
	},
	"scripts": {
		"clean": "rm -rf dist && rm -rf shared",
		"compile:cjs": "babel src --config-file ./babel.config.cjs.js --extensions='.js,.jsx,.ts,.tsx' --out-dir dist/cjs",
		"compile:esm": "babel src --extensions='.js,.jsx,.ts,.tsx' --out-dir dist/esm",
		"compile": "npm run compile:cjs && npm run compile:esm",
		"prepublishOnly": "npm run clean && npm run compile && node copy-styles.js",
		"postpublish": "npm run clean",
		"build": "npm run clean && npm run compile && node copy-styles.js"
	}
}
