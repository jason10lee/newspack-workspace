{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "newspack/comments-panel",
	"title": "Comments Panel",
	"category": "newspack",
	"description": "A button that opens a panel containing the post's comments. Intended for single post templates.",
	"keywords": [ "comments", "panel", "overlay", "drawer", "discussion" ],
	"textdomain": "newspack-plugin",
	"supports": {
		"html": false,
		"anchor": true,
		"spacing": {
			"margin": true,
			"__experimentalDefaultControls": {
				"margin": false
			}
		}
	},
	"editorStyle": "file:../../../dist/blocks.css",
	"style": "file:../../../dist/blocks.css",
	"viewScript": "file:../../../dist/comments-panel-block.js"
}
