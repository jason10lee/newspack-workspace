{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "newspack-profiles/conditional-style",
	"title": "Conditional Style",
	"description": "A block that applies conditional styles based on a specified field value.",
	"category": "design",
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"ariaLabel": true,
		"html": false,
		"shadow": true,
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"dimensions": {
			"minHeight": true
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"layout": false
	},
	"usesContext": [ "remote-data-blocks/remoteData" ],
	"attributes": {
		"fieldName": {
			"type": "string",
			"default": ""
		},
		"styles": {
			"type": "object",
			"default": {}
		},
		"fallbackStyle": {
			"type": "object",
			"default": {
				"textColor": "#000000",
				"backgroundColor": "#f3f4f6"
			}
		}
	},
	"textdomain": "newspack-profiles",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
