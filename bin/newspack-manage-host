#!/bin/bash
# Wrapper script for managing loopback aliases and /etc/hosts entries.
# Intended to be granted passwordless sudo via a sudoers drop-in,
# so that non-interactive processes (e.g. AI agents) can set up
# networking for isolated environments without a password prompt.
#
# Only allows:
#   - Adding/removing loopback aliases on lo0 (127.0.0.*)
#   - Adding /etc/hosts entries for 127.0.0.* -> *.test / *.local domains
#   - Removing /etc/hosts entries for *.test / *.local domains

set -euo pipefail

# Hosts file path. Overridable for tests via an env var; sudo's env_reset means
# this override does NOT survive a sudo invocation, so the privileged path always
# uses /etc/hosts. Tests invoke the wrapper directly (no sudo) with the override.
HOSTS_FILE="${NEWSPACK_MANAGE_HOST_HOSTS_FILE:-/etc/hosts}"

usage() {
    echo "Usage:"
    echo "  $0 alias-add <127.0.0.X>"
    echo "  $0 alias-remove <127.0.0.X>"
    echo "  $0 host-add <127.0.0.X> <domain.test> [env-name]"
    echo "  $0 host-remove <domain.test>"
    exit 1
}

validate_loopback_ip() {
    if [[ ! "$1" =~ ^127\.0\.0\.[0-9]+$ ]]; then
        echo "Error: invalid loopback IP '$1' (must be 127.0.0.X)" >&2
        exit 1
    fi
}

validate_local_domain() {
    if [[ ! "$1" =~ ^[a-zA-Z0-9._-]+\.(test|local)$ ]]; then
        echo "Error: invalid domain '$1' (must end in .test or .local)" >&2
        exit 1
    fi
}

validate_env_name() {
    if [[ ! "$1" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        echo "Error: invalid env name '$1' (alphanumeric, hyphens, underscores only)" >&2
        exit 1
    fi
}

[[ $# -lt 2 ]] && usage

case "$1" in
    alias-add)
        validate_loopback_ip "$2"
        ifconfig lo0 alias "$2"
        ;;
    alias-remove)
        validate_loopback_ip "$2"
        ifconfig lo0 -alias "$2"
        ;;
    host-add)
        [[ $# -lt 3 ]] && usage
        validate_loopback_ip "$2"
        validate_local_domain "$3"
        # Dedup tolerates a trailing marker: match domain followed by EOL or whitespace.
        dedup_escaped="${3//./\\.}"
        if ! grep -Eq "[[:space:]]${dedup_escaped}([[:space:]]|$)" "$HOSTS_FILE" 2>/dev/null; then
            if [[ $# -ge 4 && -n "$4" ]]; then
                validate_env_name "$4"
                echo "$2 $3 # newspack-env:$4" >> "$HOSTS_FILE"
            else
                echo "$2 $3" >> "$HOSTS_FILE"
            fi
        fi
        ;;
    host-remove)
        validate_local_domain "$2"
        escaped="${2//./\\.}"
        # Match the domain followed by EOL or a trailing marker; BSD sed first, GNU fallback.
        sed_expr="/[[:space:]]${escaped}\\([[:space:]].*\\)\\{0,1\\}\$/d"
        sed -i '' "$sed_expr" "$HOSTS_FILE" 2>/dev/null || sed -i "$sed_expr" "$HOSTS_FILE"
        ;;
    *)
        usage
        ;;
esac
