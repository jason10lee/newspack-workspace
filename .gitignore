.env
# Standalone/local plugin & theme checkouts outside the monorepo (see AGENTS.md);
# mounted at /newspack-repos and symlinked into the active site. The
# repos/{plugins,themes} dirs are tracked (.gitkeep); their contents are not.
repos/plugins/*
repos/themes/*
!repos/plugins/.gitkeep
!repos/themes/.gitkeep
logs
html
data
bin/secrets.json
snapshots
manager-html
additional-sites-html
bin/manager.private.key
bin/manager.public.key
.DS_Store
bin/newspack-network/nodes-keys.json
bin/newspack-network/service-accounts.secret
rootCA.pem
worktrees
envs
docker-compose.env-*.yml
.claude/settings.local.json
node_modules/
.pnpm-store/
vendor/
composer.lock
packages/*/dist/
packages/*/build/
packages/components/shared/
packages/components/colors/
plugins/*/package-lock.json
themes/*/package-lock.json
packages/*/package-lock.json
